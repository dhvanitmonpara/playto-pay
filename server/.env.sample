DEBUG=0
SECRET_KEY=replace-with-strong-secret

ALLOWED_HOSTS=your-api-domain.com,your-vps-ip
CSRF_TRUSTED_ORIGINS=https://your-api-domain.com,https://your-vercel-app.vercel.app
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

CELERY_BROKER_URL=rediss://default:PASSWORD@HOST:PORT
CELERY_RESULT_BACKEND=rediss://default:PASSWORD@HOST:PORT